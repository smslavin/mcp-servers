# intervals.icu API credentials
# Your athlete ID (found in your intervals.icu profile URL, e.g. i12345)
INTERVALS_ATHLETE_ID=

# Your API key from intervals.icu Settings > Developer Settings
INTERVALS_API_KEY=

# HRV4Training: local CSV directory (takes priority if set)
HRV4TRAINING_CSV_DIR=

# HRV4Training: Dropbox app credentials (used if CSV_DIR is not set)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_ACCESS_TOKEN=
DROPBOX_REFRESH_TOKEN=
DROPBOX_TOKEN_EXPIRES_AT=
